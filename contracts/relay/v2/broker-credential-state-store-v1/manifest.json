      "compareAndPublishOutcomes": {
        "swapped": ["outcome", "revision"],
        "already_same": ["outcome", "revision"],
        "conflict": ["outcome", "revision"],
        "uncertain": ["outcome"]
      },
      "alreadySameRule": "exact-current-bytes-equal-next-before-revision-conflict",
      "uncertainRule": "no-revision-and-reconcile-by-a-new-exclusive-read",
      "byteOwnership": "read-returns-copy-and-publish-captures-copy-before-await"
    },
    "close": {
      "idempotent": true,
      "rejectsNewTransactionsAtBarrierStart": true,
      "waitsForAdmittedTransactions": true,
      "resolvesAfterNativeResourcesClose": true
    }
  },
  "binaryStorage": {
    "formatVersion": 1,
    "logicalObjects": ["header0", "header1", "payload0", "payload1"],
    "headerBytes": 128,
    "maxPayloadBytes": 67108864,
    "byteOrder": "little-endian",
    "digest": "sha256",
    "headerLayout": [
      { "name": "magic", "offset": 0, "bytes": 8, "valueAscii": "TWV2BCS1" },
      { "name": "formatVersion", "offset": 8, "bytes": 2, "type": "u16", "value": 1 },
      { "name": "slot", "offset": 10, "bytes": 1, "type": "u8", "values": [0, 1] },
      { "name": "flags", "offset": 11, "bytes": 1, "type": "u8", "value": 0 },
      { "name": "headerLength", "offset": 12, "bytes": 4, "type": "u32", "value": 128 },
      { "name": "generation", "offset": 16, "bytes": 8, "type": "u64", "minimum": "1", "maximum": "18446744073709551615" },
      { "name": "payloadLength", "offset": 24, "bytes": 8, "type": "u64", "minimum": "1", "maximum": "67108864" },
      { "name": "payloadDigest", "offset": 32, "bytes": 32, "type": "sha256-raw" },
      { "name": "reserved", "offset": 64, "bytes": 32, "value": "all-zero" },
      { "name": "headerChecksum", "offset": 96, "bytes": 32, "type": "sha256-raw", "covers": [0, 96] }
    ],
    "selection": {
      "missing": "all-four-logical-objects-absent",
      "present": "highest-complete-generation",
      "validDualGenerationDelta": "exactly-one",
      "slotRule": "slot-equals-generation-minus-one-modulo-two",
      "sameOrSkippedGeneration": "STORE_CORRUPT",
      "singleHeaderRule": "only-complete-generation-one-slot-zero",
      "unknownChecksumValidVersionOrFlags": "STORE_FORMAT_UNSUPPORTED",
      "highestIncompleteOrAmbiguous": "STORE_CORRUPT",
      "lowerIncompleteOrHeaderlessInactivePayload": "ignored-only-when-a-complete-immediate-successor-exists"
    },
    "publication": [
      "hold-the-exclusive-transaction",
      "select-the-inactive-slot-and-next-generation",
      "atomically-replace-and-durably-sync-the-inactive-payload-object",
      "atomically-replace-and-durably-sync-the-matching-header-object",
      "durably-sync-container-metadata-required-by-the-platform",
      "return-swapped-only-after-all-durability-steps-are-proven"
