      "createOpen": ["O_RDWR", "O_CREAT", "O_EXCL", "O_NOFOLLOW", "O_CLOEXEC"],
      "createModeOctal": "0600",
      "requiredPostOpenDescriptorFlag": "FD_CLOEXEC",
      "forbiddenOpenFlags": ["O_TRUNC"],
      "write": "fixed-journal-from-offset-zero",
      "read": "same-sole-descriptor-exact-journal-on-close",
      "release": "unlinkat-claim-then-exactly-once-raw-close"
    },
