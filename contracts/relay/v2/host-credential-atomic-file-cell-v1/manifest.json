      "createOpen": ["O_RDWR", "O_NOFOLLOW", "O_CLOEXEC", "O_CREAT", "O_EXCL"],
      "createModeOctal": "0600",
      "forbiddenOpenFlags": ["O_TRUNC", "O_EXLOCK"],
      "primitive": "traditional-process-owned-F_SETLK",
      "record": { "type": "F_WRLCK", "whence": "SEEK_SET", "start": 0, "length": 0 },
