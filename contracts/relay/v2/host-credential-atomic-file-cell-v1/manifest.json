      "ok": ["abiVersion", "operation", "outcome", "current"],
      "error": ["abiVersion", "operation", "outcome", "error"]
    },
    "compare_and_swap": {
      "swapped": ["abiVersion", "operation", "outcome"],
      "conflict": ["abiVersion", "operation", "outcome", "current"],
      "uncertain": ["abiVersion", "operation", "outcome"],
      "error": ["abiVersion", "operation", "outcome", "error"]
    },
    "close": {
      "closed": ["abiVersion", "operation", "outcome"],
      "error": ["abiVersion", "operation", "outcome", "error"]
    },
