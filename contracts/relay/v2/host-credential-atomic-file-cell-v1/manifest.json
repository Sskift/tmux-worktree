  "lifecycle": {
    "nodeOwnsRawHandle": true,
    "openFailureAfterHandleCapture": "exactly-once-raw-close-before-no-publication",
    "unknownNativeError": "permanent-wrapper-fence",
    "uncertain": "permanent-wrapper-fence-without-current-or-revision",
    "fallbackAllowed": false,
    "closeAndDrain": {
      "stablePromise": true,
      "rejectsNewOperationsAtBarrierStart": true,
      "rawCloseCount": "exactly-once",
