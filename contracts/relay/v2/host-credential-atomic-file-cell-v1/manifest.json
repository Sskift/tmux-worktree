    "acceptedByCompareAndSwap": "same-wrapper-current-unconsumed-exact-token-only",
    "rejectedBeforeRawMutation": ["foreign", "copy", "replay", "stale", "forged"]
  },
  "rawErrorUnion": {
    "shape": ["code"],
    "codes": [
      "NATIVE_INTERFACE_INVALID",
      "CELL_BUSY",
      "CELL_CLOSED",
      "CELL_CORRUPT",
      "CELL_IDENTITY_UNCERTAIN",
      "CELL_IO",
