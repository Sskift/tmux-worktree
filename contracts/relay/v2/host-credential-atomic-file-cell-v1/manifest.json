      "formatVersion": 1,
      "byteOrder": "little-endian",
      "byteLength": 192,
      "magicAscii": "TWV2HAC1",
      "state": "ADMISSION_HELD_NO_CREDENTIAL_MUTATION",
      "claimIdBytes": 32,
      "integrity": "SHA-256-over-bytes-0-through-159",
      "reservedMustBeZero": true,
