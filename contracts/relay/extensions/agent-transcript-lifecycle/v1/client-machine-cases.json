[
  {
    "name": "live-duplicate-gap-and-replay-notify-once",
    "scenarios": ["replay-gap", "notification-dedupe"],
    "initial": {
      "support": "available",
      "timelineEpoch": "timeline-1",
      "lastAgentSeq": "5",
      "notificationBaselineAgentSeq": "5",
      "notificationPermission": "granted",
      "profileActive": true,
      "lifecycleStates": { "turn:run-1:turn-1": "running" },
      "commandStates": {}
    },
    "steps": [
      {
        "input": { "kind": "agent_event", "timelineEpoch": "timeline-1", "agentEventSeq": "6", "eventId": "event-6", "record": { "recordType": "lifecycle", "sourceEpoch": "source-client", "scope": "turn", "runId": "run-1", "turnId": "turn-1", "state": "waiting_for_user" } },
        "expect": { "disposition": "applied", "lastAgentSeq": "6", "lifecycleState": "waiting_for_user", "notification": "shown" }
      },
      {
        "input": { "kind": "agent_event", "timelineEpoch": "timeline-1", "agentEventSeq": "6", "eventId": "event-6", "record": { "recordType": "lifecycle", "sourceEpoch": "source-client", "scope": "turn", "runId": "run-1", "turnId": "turn-1", "state": "waiting_for_user" } },
        "expect": { "disposition": "duplicate", "lastAgentSeq": "6", "lifecycleState": "waiting_for_user", "notification": "none" }
      },
      {
        "input": { "kind": "agent_event", "timelineEpoch": "timeline-1", "agentEventSeq": "8", "eventId": "event-8", "record": { "recordType": "lifecycle", "sourceEpoch": "source-client", "scope": "turn", "runId": "run-1", "turnId": "turn-1", "state": "completed" } },
        "expect": { "disposition": "gap_resync", "lastAgentSeq": "6", "lifecycleState": "waiting_for_user", "notification": "none" }
      },
      {
        "input": { "kind": "agent_event", "timelineEpoch": "timeline-1", "agentEventSeq": "7", "eventId": "event-7", "record": { "recordType": "lifecycle", "sourceEpoch": "source-client", "scope": "turn", "runId": "run-1", "turnId": "turn-1", "state": "running" } },
        "expect": { "disposition": "applied", "lastAgentSeq": "7", "lifecycleState": "running", "notification": "none" }
      },
      {
        "input": { "kind": "agent_event", "timelineEpoch": "timeline-1", "agentEventSeq": "8", "eventId": "event-8", "record": { "recordType": "lifecycle", "sourceEpoch": "source-client", "scope": "turn", "runId": "run-1", "turnId": "turn-1", "state": "completed" } },
        "expect": { "disposition": "applied", "lastAgentSeq": "8", "lifecycleState": "completed", "notification": "shown" }
      }
    ]
  },
  {
    "name": "continuity-conflict-quarantines-until-trusted-snapshot",
    "scenarios": ["replay-gap", "notification-dedupe"],
    "initial": {
      "support": "available",
      "timelineEpoch": "timeline-conflict",
      "lastAgentSeq": "5",
      "notificationBaselineAgentSeq": "5",
      "notificationPermission": "granted",
      "profileActive": true,
      "lifecycleStates": { "turn:run-conflict:turn-conflict": "running" },
      "commandStates": {}
    },
    "steps": [
      {
        "input": { "kind": "agent_event", "timelineEpoch": "timeline-conflict", "agentEventSeq": "6", "eventId": "event-conflict-6", "record": { "recordType": "lifecycle", "sourceEpoch": "source-client", "scope": "turn", "runId": "run-conflict", "turnId": "turn-conflict", "state": "waiting_for_user" } },
        "expect": { "disposition": "applied", "lastAgentSeq": "6", "lifecycleState": "waiting_for_user", "requiresSnapshot": false, "notification": "shown" }
      },
      {
        "input": { "kind": "agent_event", "timelineEpoch": "timeline-conflict", "agentEventSeq": "6", "eventId": "event-conflict-6", "record": { "recordType": "lifecycle", "sourceEpoch": "source-client", "scope": "turn", "runId": "run-conflict", "turnId": "turn-conflict", "state": "completed" } },
        "expect": { "disposition": "continuity_conflict", "lastAgentSeq": "6", "lifecycleState": "waiting_for_user", "requiresSnapshot": true, "notification": "none" }
      },
      {
        "input": { "kind": "agent_event", "timelineEpoch": "timeline-conflict", "agentEventSeq": "7", "eventId": "event-conflict-7", "record": { "recordType": "lifecycle", "sourceEpoch": "source-client", "scope": "turn", "runId": "run-conflict", "turnId": "turn-conflict", "state": "running" } },
        "expect": { "disposition": "continuity_conflict", "lastAgentSeq": "6", "lifecycleState": "waiting_for_user", "requiresSnapshot": true, "notification": "none" }
      },
      {
        "input": { "kind": "snapshot_request_started", "requestToken": "snapshot-conflict" },
        "expect": { "disposition": "config_applied", "lastAgentSeq": "6", "requiresSnapshot": true }
      },
      {
        "input": { "kind": "snapshot_commit", "timelineEpoch": "timeline-conflict", "localGeneration": "1", "requestToken": "snapshot-conflict", "throughAgentSeq": "7", "records": [{ "recordType": "lifecycle", "sourceEpoch": "source-client", "scope": "turn", "runId": "run-conflict", "turnId": "turn-conflict", "state": "running", "lifecycleEventId": "event-conflict-7-snapshot", "agentEventSeq": "7" }] },
        "expect": { "disposition": "snapshot_applied", "lastAgentSeq": "7", "notificationBaselineAgentSeq": "5", "requiresSnapshot": false, "notification": "none" }
      },
      {
        "input": { "kind": "agent_event", "timelineEpoch": "timeline-conflict", "agentEventSeq": "8", "eventId": "event-conflict-8", "record": { "recordType": "lifecycle", "sourceEpoch": "source-client", "scope": "turn", "runId": "run-conflict", "turnId": "turn-conflict", "state": "completed" } },
        "expect": { "disposition": "applied", "lastAgentSeq": "8", "lifecycleState": "completed", "requiresSnapshot": false, "notification": "shown" }
      }
    ]
  },
  {
    "name": "command-ledger-and-agent-lifecycle-are-separate-lanes",
    "scenarios": ["command-lifecycle-independent"],
    "initial": {
      "support": "available",
      "timelineEpoch": "timeline-2",
      "lastAgentSeq": "0",
      "notificationBaselineAgentSeq": "0",
      "notificationPermission": "granted",
      "profileActive": true,
      "lifecycleStates": {},
      "commandStates": { "command-1": "accepted" }
    },
    "steps": [
      {
        "input": { "kind": "command_status", "commandId": "command-1", "state": "succeeded" },
        "expect": { "disposition": "command_applied", "commandState": "succeeded", "lifecycleState": null, "lastAgentSeq": "0" }
      },
      {
        "input": { "kind": "agent_event", "timelineEpoch": "timeline-2", "agentEventSeq": "1", "eventId": "event-c1", "record": { "recordType": "lifecycle", "sourceEpoch": "source-client", "scope": "run", "runId": "run-c1", "turnId": null, "state": "running" } },
        "expect": { "disposition": "applied", "commandState": "succeeded", "lifecycleState": "running", "lastAgentSeq": "1", "notification": "none" }
      },
      {
        "input": { "kind": "agent_event", "timelineEpoch": "timeline-2", "agentEventSeq": "2", "eventId": "event-c2", "record": { "recordType": "lifecycle", "sourceEpoch": "source-client", "scope": "turn", "runId": "run-c1", "turnId": "turn-c1", "state": "running" } },
        "expect": { "disposition": "applied", "commandState": "succeeded", "lifecycleState": "running", "lastAgentSeq": "2", "notification": "none" }
      },
      {
        "input": { "kind": "agent_event", "timelineEpoch": "timeline-2", "agentEventSeq": "3", "eventId": "event-c3", "record": { "recordType": "lifecycle", "sourceEpoch": "source-client", "scope": "turn", "runId": "run-c1", "turnId": "turn-c1", "state": "failed" } },
        "expect": { "disposition": "applied", "commandState": "succeeded", "lifecycleState": "failed", "lastAgentSeq": "3", "notification": "shown" }
      }
    ]
  },
  {
    "name": "permission-and-profile-suppression-are-durable",
    "scenarios": ["notification-dedupe"],
    "initial": {
      "support": "available",
      "timelineEpoch": "timeline-3",
      "lastAgentSeq": "1",
      "notificationBaselineAgentSeq": "1",
      "notificationPermission": "denied",
      "profileActive": true,
      "lifecycleStates": { "turn:run-3:turn-3": "running" },
      "commandStates": {}
    },
    "steps": [
      {
        "input": { "kind": "agent_event", "timelineEpoch": "timeline-3", "agentEventSeq": "2", "eventId": "event-n2", "record": { "recordType": "lifecycle", "sourceEpoch": "source-client", "scope": "turn", "runId": "run-3", "turnId": "turn-3", "state": "waiting_for_user" } },
        "expect": { "disposition": "applied", "lastAgentSeq": "2", "notification": "suppressed_permission" }
      },
      {
        "input": { "kind": "agent_event", "timelineEpoch": "timeline-3", "agentEventSeq": "2", "eventId": "event-n2", "record": { "recordType": "lifecycle", "sourceEpoch": "source-client", "scope": "turn", "runId": "run-3", "turnId": "turn-3", "state": "waiting_for_user" } },
        "expect": { "disposition": "duplicate", "lastAgentSeq": "2", "notification": "none" }
      },
      {
        "input": { "kind": "client_config", "notificationPermission": "granted", "profileActive": false },
        "expect": { "disposition": "config_applied", "lastAgentSeq": "2" }
      },
      {
        "input": { "kind": "agent_event", "timelineEpoch": "timeline-3", "agentEventSeq": "3", "eventId": "event-n3", "record": { "recordType": "lifecycle", "sourceEpoch": "source-client", "scope": "turn", "runId": "run-3", "turnId": "turn-3", "state": "running" } },
        "expect": { "disposition": "applied", "lastAgentSeq": "3", "notification": "none" }
      },
      {
        "input": { "kind": "agent_event", "timelineEpoch": "timeline-3", "agentEventSeq": "4", "eventId": "event-n4", "record": { "recordType": "lifecycle", "sourceEpoch": "source-client", "scope": "turn", "runId": "run-3", "turnId": "turn-3", "state": "completed" } },
        "expect": { "disposition": "applied", "lastAgentSeq": "4", "notification": "suppressed_inactive_profile" }
      }
    ]
  },
